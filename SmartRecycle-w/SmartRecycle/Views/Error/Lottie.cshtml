<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطأ @ViewBag.ErrorCode</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }

        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.3;
        }

        .bg-shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            animation: float 20s infinite ease-in-out;
        }

        .shape1 {
            width: 400px;
            height: 400px;
            background: rgba(102, 126, 234, 0.5);
            top: -100px;
            left: -100px;
            animation-delay: 0s;
        }

        .shape2 {
            width: 500px;
            height: 500px;
            background: rgba(240, 147, 251, 0.5);
            bottom: -150px;
            right: -150px;
            animation-delay: 3s;
        }

        .shape3 {
            width: 300px;
            height: 300px;
            background: rgba(118, 75, 162, 0.5);
            top: 50%;
            left: 50%;
            animation-delay: 6s;
        }

        @@keyframes float {
            0%, 100%

        {
            transform: translate(0, 0) scale(1);
        }

        33% {
            transform: translate(50px, -50px) scale(1.1);
        }

        66% {
            transform: translate(-50px, 50px) scale(0.9);
        }

        }

        .error-container {
            position: relative;
            z-index: 10;
            text-align: center;
            max-width: 1000px;
            width: 90%;
            padding: 60px 40px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.5);
            animation: containerAppear 0.8s ease-out;
        }

        @@keyframes containerAppear {
            from

        {
            opacity: 0;
            transform: translateY(50px) scale(0.9);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        .lottie-wrapper {
            width: 100%;
            max-width: 400px;
            height: 300px;
            margin: 0 auto 30px;
        }

        .error-code-badge {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-size: 80px;
            font-weight: 900;
            padding: 20px 50px;
            border-radius: 25px;
            margin-bottom: 30px;
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.4), inset 0 -5px 15px rgba(0, 0, 0, 0.2);
            animation: badgePulse 2s ease-in-out infinite;
        }

        @@keyframes badgePulse {
            0%, 100%

        {
            transform: scale(1);
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.4), inset 0 -5px 15px rgba(0, 0, 0, 0.2);
        }

        50% {
            transform: scale(1.05);
            box-shadow: 0 20px 45px rgba(102, 126, 234, 0.6), inset 0 -5px 15px rgba(0, 0, 0, 0.3);
        }

        }

        .error-title {
            font-size: 42px;
            font-weight: 800;
            color: #2d3748;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .error-subtitle {
            font-size: 22px;
            color: #4a5568;
            margin-bottom: 30px;
            line-height: 1.6;
            font-weight: 500;
        }

        .message-box {
            background: linear-gradient(135deg, #f6f8ff 0%, #f0f4ff 100%);
            border-radius: 20px;
            padding: 30px;
            margin: 30px 0;
            border: 2px solid #e0e7ff;
            position: relative;
            overflow: hidden;
        }

            .message-box::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
                animation: shimmer 3s infinite;
            }

        @@keyframes shimmer {
            0%

        {
            left: -100%;
        }

        100% {
            left: 100%;
        }

        }

        .message-icon {
            font-size: 50px;
            margin-bottom: 15px;
            animation: bounce 2s ease-in-out infinite;
        }

        @@keyframes bounce {
            0%, 100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }

        }

        .message-text {
            font-size: 18px;
            color: #4a5568;
            line-height: 1.8;
            position: relative;
            z-index: 1;
        }

        .tech-info {
            background: #2d3748;
            color: #a0aec0;
            border-radius: 15px;
            padding: 20px;
            margin: 25px 0;
            text-align: left;
            direction: ltr;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.5);
        }

            .tech-info strong {
                color: #667eea;
            }

            .tech-info::before {
                content: '> ';
                color: #667eea;
            }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(239, 68, 68, 0.1);
            padding: 12px 25px;
            border-radius: 50px;
            margin: 20px 0;
            border: 2px solid rgba(239, 68, 68, 0.3);
        }

        .status-dot {
            width: 12px;
            height: 12px;
            background: #ef4444;
            border-radius: 50%;
            animation: blink 1.5s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100%

        {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        }

        .status-text {
            color: #ef4444;
            font-weight: 600;
            font-size: 16px;
        }

        .action-buttons {
            display: flex;
            gap: 20px;
            margin-top: 40px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-premium {
            padding: 20px 50px;
            font-size: 20px;
            font-weight: 700;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            position: relative;
            overflow: hidden;
        }

            .btn-premium::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 0;
                height: 0;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.3);
                transform: translate(-50%, -50%);
                transition: width 0.6s, height 0.6s;
            }

            .btn-premium:hover::before {
                width: 300px;
                height: 300px;
            }

            .btn-premium span {
                position: relative;
                z-index: 1;
            }

        .btn-home {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }

            .btn-home:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(102, 126, 234, 0.6);
            }

        .btn-back {
            background: white;
            color: #667eea;
            border: 3px solid #667eea;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
        }

            .btn-back:hover {
                background: #667eea;
                color: white;
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
            }

        .support-link {
            margin-top: 30px;
            font-size: 16px;
            color: #718096;
        }

            .support-link a {
                color: #667eea;
                text-decoration: none;
                font-weight: 600;
                transition: color 0.3s;
            }

                .support-link a:hover {
                    color: #764ba2;
                    text-decoration: underline;
                }

        @@media (max-width: 768px) {
            .error-container

        {
            padding: 40px 25px;
        }

        .error-code-badge {
            font-size: 60px;
            padding: 15px 35px;
        }

        .error-title {
            font-size: 32px;
        }

        .error-subtitle {
            font-size: 18px;
        }

        .btn-premium {
            padding: 16px 40px;
            font-size: 18px;
        }

        .lottie-wrapper {
            height: 250px;
        }

        }
    </style>
</head>
<body>
    <div class="animated-bg">
        <div class="bg-shape shape1"></div>
        <div class="bg-shape shape2"></div>
        <div class="bg-shape shape3"></div>
    </div>

    <div class="error-container">
        <div class="lottie-wrapper" id="lottie-animation"></div>

        <div class="error-code-badge">@ViewBag.ErrorCode</div>

        <h1 class="error-title">عذراً! حدث خطأ</h1>
        <p class="error-subtitle">@ViewBag.ErrorMessage</p>

        <div class="status-indicator">
            <span class="status-dot"></span>
            <span class="status-text">النظام قيد الفحص</span>
        </div>

        <div class="message-box">
            <div class="message-icon">🔍</div>
            <div class="message-text">
                لا تقلق! فريق الدعم الفني لدينا على علم بالمشكلة ويعمل على حلها.<br>
                يمكنك العودة للصفحة الرئيسية أو المحاولة مرة أخرى.
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.ErrorPath as string))
        {
            <div class="tech-info">
                <strong>ERROR DETAILS</strong><br>
                Path: @ViewBag.ErrorPath<br>
                Code: @ViewBag.ErrorCode<br>
                Time: @DateTime.Now.ToString("HH:mm:ss")
            </div>
        }

        <div class="action-buttons">
            <a href="/" class="btn-premium btn-home">
                <span>🏠 العودة للرئيسية</span>
            </a>
            <button onclick="history.back()" class="btn-premium btn-back">
                <span>↩️ رجوع</span>
            </button>
        </div>

        <div class="support-link">
            هل تحتاج مساعدة؟ <a href="/contact">تواصل مع الدعم الفني</a>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js"></script>
    <script>
        // Different Lottie animations based on error code
        const errorCode = @ViewBag.ErrorCode;
        let animationPath;

        // Select appropriate animation
        if (errorCode == 404) {
            animationPath = 'https://lottie.host/d7162f96-3cf7-4dda-8023-6f0c0b6f1b6a/IpccYbwUr9.json'; // 404 animation
        } else if (errorCode == 500) {
            animationPath = 'https://lottie.host/647c0a90-e574-4b52-9a5d-b7c012e0c469/RCda4YaFiq.json'; // Server error
        } else if (errorCode == 403) {
            animationPath = 'https://lottie.host/ba8ec7ac-5d50-404f-96e6-a186fa6e2ea3/qzCcYdS0kB.json'; // Access denied
        } else {
            animationPath = 'https://lottie.host/e5e0b9df-9f53-4a25-8c39-c4f98ae4df31/0wSLfKpqsF.json'; // Generic error
        }

        // Load Lottie animation
        const animation = lottie.loadAnimation({
            container: document.getElementById('lottie-animation'),
            renderer: 'svg',
            loop: true,
            autoplay: true,
            path: animationPath
        });

        // Add some interactivity
        document.querySelector('.error-container').addEventListener('mouseenter', () => {
            animation.setSpeed(1.5);
        });

        document.querySelector('.error-container').addEventListener('mouseleave', () => {
            animation.setSpeed(1);
        });
    </script>
</body>
</html>