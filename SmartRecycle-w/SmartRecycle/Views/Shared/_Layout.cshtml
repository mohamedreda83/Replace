                                            <i class="fas fa-box"></i> إدارة المنتجات
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Categories" asp-action="Index">
                                            <i class="fas fa-tags"></i> إدارة الفئات
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Orders" asp-action="Index">
                                            <i class="fas fa-shipping-fast"></i> إدارة الطلبات
                                        </a>
                                    </li>
