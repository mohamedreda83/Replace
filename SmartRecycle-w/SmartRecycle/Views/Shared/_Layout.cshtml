@{
    ViewData["Title"] = ViewData["Title"] ?? "RePlace";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RePlace</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts - Cairo -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Overlay للسايدبار -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Mobile Sidebar -->
    <div class="mobile-sidebar" id="mobileSidebar">
        <div class="sidebar-header">
            <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-recycle"></i>
                <span>RePlace</span>
            </a>
            <button class="sidebar-close" id="sidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <div class="sidebar-user-info">
                <div class="sidebar-user-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="sidebar-user-details">
                    <div class="sidebar-user-name">@User.Identity.Name</div>
                    <div class="sidebar-user-points">
                        <i class="fas fa-star"></i>
                        <span id="sidebarPointsDisplay">@User.FindFirst("Point")?.Value</span>
                    </div>
                </div>
            </div>
        }

        <ul class="sidebar-nav">
            @if (User.Identity.IsAuthenticated)
            {
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Shop" asp-action="Index">
                        <i class="fas fa-store"></i>
                        <span>المتجر</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Shop" asp-action="Cart">
                        <i class="fas fa-shopping-cart"></i>
                        <span>سلة المشتريات</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <button class="sidebar-dropdown-toggle" data-dropdown="ordersDropdown">
                        <span>
                            <i class="fas fa-clipboard-list"></i>
                            طلباتي
                        </span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <ul class="sidebar-dropdown" id="ordersDropdown">
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Order" asp-action="Index">
                                <i class="fas fa-box"></i> طلباتي السابقة
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Order" asp-action="MyInvoices">
                                <i class="fas fa-file-invoice"></i> فواتيري
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-user-circle"></i>
                        <span>الملف الشخصي</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="UserProfile" asp-action="Edit">
                        <i class="fas fa-edit"></i>
                        <span>تعديل الملف الشخصي</span>
                    </a>
                </li>
            }

            <li class="sidebar-nav-item">
                <a class="sidebar-nav-link" asp-area="" asp-controller="Account" asp-action="Download">
                    <i class="fas fa-download"></i>
                    <span>تنزيل APK</span>
                </a>
            </li>

            @if (User.IsInRole("admin"))
            {
                <div class="sidebar-divider"></div>
                <li class="sidebar-nav-item">
                    <button class="sidebar-dropdown-toggle" data-dropdown="adminDropdown">
                        <span>
                            <i class="fas fa-cogs"></i>
                            لوحة الإدارة
                        </span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <ul class="sidebar-dropdown" id="adminDropdown">
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Products" asp-action="Index">
                                <i class="fas fa-box"></i> إدارة المنتجات
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Categories" asp-action="Index">
                                <i class="fas fa-tags"></i> إدارة الفئات
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Orders" asp-action="Index">
                                <i class="fas fa-shipping-fast"></i> إدارة الطلبات
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Orders" asp-action="SearchOrder">
                                <i class="fas fa-search"></i> تسليم طلبات
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Orders" asp-action="BranchOrders">
                                <i class="fas fa-building"></i> مشاهدة طلبات الفرع
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-dropdown-item" asp-area="" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-users-cog"></i> إدارة المستخدمين
                            </a>
                        </li>
                    </ul>
                </li>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <div class="sidebar-divider"></div>
                <li class="sidebar-nav-item">
                    <form id="sidebarLogoutForm" method="post" action="@Url.Action("Logout", "Account")">
                        @Html.AntiForgeryToken()
                        <a class="sidebar-nav-link" href="javascript:document.getElementById('sidebarLogoutForm').submit()">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>تسجيل خروج</span>
                        </a>
                    </form>
                </li>
            }
            else
            {
                <div class="sidebar-divider"></div>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Account" asp-action="Login">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>تسجيل دخول</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Account" asp-action="Register">
                        <i class="fas fa-user-plus"></i>
                        <span>إنشاء حساب</span>
                    </a>
                </li>
            }
        </ul>
    </div>

