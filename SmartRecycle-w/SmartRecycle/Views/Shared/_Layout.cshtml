                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery (if needed) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>

    <!-- Custom JavaScript -->
    <script src="~/js/smart-recycle.js" asp-append-version="true"></script>

    <!-- Sidebar JavaScript -->
    <script>
        // فتح وإغلاق السايدبار
        const sidebarToggle = document.getElementById('sidebarToggle');
        const mobileSidebar = document.getElementById('mobileSidebar');
        const sidebarClose = document.getElementById('sidebarClose');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            mobileSidebar.classList.add('show');
            sidebarOverlay.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            mobileSidebar.classList.remove('show');
            sidebarOverlay.classList.remove('show');
            document.body.style.overflow = '';
        }

        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', openSidebar);
        }

        if (sidebarClose) {
            sidebarClose.addEventListener('click', closeSidebar);
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', closeSidebar);
        }

        // إغلاق السايدبار عند الضغط على أي رابط
        const sidebarLinks = document.querySelectorAll('.sidebar-nav-link, .sidebar-dropdown-item');
        sidebarLinks.forEach(link => {
            link.addEventListener('click', () => {
                setTimeout(closeSidebar, 200);
            });
        });

        // Dropdown toggles في السايدبار
        const dropdownToggles = document.querySelectorAll('.sidebar-dropdown-toggle');
        dropdownToggles.forEach(toggle => {
            toggle.addEventListener('click', function() {
                const dropdownId = this.getAttribute('data-dropdown');
                const dropdown = document.getElementById(dropdownId);

                // إغلاق جميع الـ dropdowns الأخرى
                document.querySelectorAll('.sidebar-dropdown').forEach(d => {
                    if (d.id !== dropdownId) {
                        d.classList.remove('show');
                    }
                });

                document.querySelectorAll('.sidebar-dropdown-toggle').forEach(t => {
                    if (t !== this) {
                        t.classList.remove('active');
                    }
                });

                // تبديل الحالة للـ dropdown الحالي
                dropdown.classList.toggle('show');
                this.classList.toggle('active');
            });
        });

        // إغلاق السايدبار عند تكبير الشاشة
        window.addEventListener('resize', function() {
            if (window.innerWidth > 991) {
                closeSidebar();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>