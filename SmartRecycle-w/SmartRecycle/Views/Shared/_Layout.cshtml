                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Order" asp-action="Index">
                                            <i class="fas fa-box"></i> طلباتي السابقة
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Order" asp-action="MyInvoices">
                                            <i class="fas fa-box"></i>فواتيري
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
