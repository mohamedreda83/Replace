@model IEnumerable<SmartRecycle.Models.Product>
@{
    ViewData["Title"] = "المتجر";
}

<link href="~/css/shop.css" rel="stylesheet" />

<div class="container py-5 shop-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- القائمة الجانبية - ستختفي في الشاشات الصغيرة -->
        <div class="col-md-3 shop-sidebar">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="fas fa-list-ul me-2"></i>الفئات</h4>
                </div>
                <div class="card-body p-0">
                    <div class="list-group rounded-0">
                        <a href="@Url.Action("Index", "Shop")" class="list-group-item list-group-item-action @(ViewBag.CategoryId == null ? "active" : "")">
                            <i class="fas fa-th-large me-2"></i> كل المنتجات
                        </a>
                        @foreach (var category in ViewBag.Categories)
                        {
                            <a href="@Url.Action("Category", "Shop", new { id = category.Id })"
                               class="list-group-item list-group-item-action @(ViewBag.CategoryId == category.Id ? "active" : "")">
                                <i class="fas fa-tag me-2"></i> @category.Name
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white p-3">
                    <h4 class="mb-0"><i class="fas fa-link me-2"></i>روابط سريعة</h4>
                </div>
                <div class="card-body p-0">
                    <div class="list-group rounded-0">
                        <a href="@Url.Action("Cart", "Shop")" class="list-group-item list-group-item-action">
                            <i class="fas fa-shopping-cart me-2"></i> سلة المشتريات
                        </a>
                        <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action">
                            <i class="fas fa-clipboard-list me-2"></i> طلباتي السابقة
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- منطقة المنتجات -->
        <div class="col-md-9 shop-products">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">
                            <i class="fas fa-store me-2"></i>
                            @(ViewBag.CategoryName ?? "جميع المنتجات")
                        </h3>
                        <div class="d-md-none">
                            <button class="btn btn-outline-light btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#categoriesModal">
                                <i class="fas fa-list-ul me-1"></i> الفئات
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body p-3 p-lg-4">
                    <div class="row g-3">
                        @if (Model.Any())
                        {
                            foreach (var product in Model)
                            {
                                <div class="col-6 col-md-4 mb-2">
                                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                                        <div class="product-image-container position-relative">
                                            <img src="@Url.Content(string.IsNullOrEmpty(product.ImageUrl) ? "~/images/no-image.jpg" : product.ImageUrl)"
                                                 class="card-img-top" alt="@product.Name">
                                            <div class="product-category-badge">
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-tag me-1"></i> @product.Category.Name
                                                </span>
                                            </div>
                                        </div>
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title product-title">@product.Name</h5>
                                            <p class="card-text product-description flex-grow-1">@product.Description</p>
                                            <div class="product-highlights mb-3">
                                                <div class="row g-2">
                                                    <div class="col-auto">
                                                        <div class="product-badge price">
                                                            <i class="fas fa-star me-1"></i> @product.PointsPrice
                                                        </div>
                                                    </div>
                                                    <div class="col-auto">
                                                        <div class="product-badge @(product.Stock > 0 ? "in-stock" : "out-stock")">
                                                            <i class="fas fa-box me-1"></i>
                                                            @if (product.Stock > 0)
                                                            {
                                                                <span>@product.Stock</span>
                                                            }
                                                            else
                                                            {
                                                                <span>نفد</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <a href="@Url.Action("Details", "Shop", new { id = product.Id })" class="btn btn-primary">
                                                <i class="fas fa-eye me-1"></i> عرض التفاصيل
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="alert alert-info text-center p-4">
                                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                                    <h5>لا توجد منتجات متاحة</h5>
                                    <p class="mb-0">لا توجد منتجات متاحة في هذه الفئة حالياً</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- نافذة منبثقة للفئات على الشاشات الصغيرة -->
<div class="modal fade" id="categoriesModal" tabindex="-1" aria-labelledby="categoriesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="categoriesModalLabel"><i class="fas fa-list-ul me-2"></i>الفئات</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body p-0">
                <div class="list-group rounded-0">
                    <a href="@Url.Action("Index", "Shop")" class="list-group-item list-group-item-action @(ViewBag.CategoryId == null ? "active" : "")" >
                        <i class="fas fa-th-large me-2"></i> كل المنتجات
                    </a>
                    @foreach (var category in ViewBag.Categories)
                    {
                        <a href="@Url.Action("Category", "Shop", new { id = category.Id })"
                           class="list-group-item list-group-item-action @(ViewBag.CategoryId == category.Id ? "active" : "")" >
                            <i class="fas fa-tag me-2"></i> @category.Name
                        </a>
                    }
                </div>

                <div class="p-3 border-top">
                    <div class="list-group">
                        <h6 class="mb-2">روابط سريعة:</h6>
                        <a href="@Url.Action("Cart", "Shop")" class="list-group-item list-group-item-action" >
                            <i class="fas fa-shopping-cart me-2"></i> سلة المشتريات
                        </a>
                        <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action" >
                            <i class="fas fa-clipboard-list me-2"></i> طلباتي السابقة
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // تأثير للصور عند التحميل
            const productImages = document.querySelectorAll('.card-img-top');
            productImages.forEach(img => {
                img.style.opacity = '0';
                img.onload = function() {
                    setTimeout(function() {
                        img.style.transition = 'opacity 0.5s ease';
                        img.style.opacity = '1';
                    }, 100);
                };
                
                // في حالة الصورة محملة بالفعل
                if (img.complete) {
                    setTimeout(function() {
                        img.style.transition = 'opacity 0.5s ease';
                        img.style.opacity = '1';
                    }, 100);
                }
            });
        });
    </script>
}