@model IEnumerable<SmartRecycle.Models.Order>
@{
    ViewData["Title"] = "طلباتي";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">سجل الطلبات</h4>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>رقم الطلب</th>
                                        <th>تاريخ الطلب</th>
                                        <th>حالة الطلب</th>
                                        <th>إجمالي النقاط</th>
                                        <th width="150">إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>@order.Id</td>
                                            <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                @switch (order.Status)
                                                {
                                                    case "معلق":
                                                        <span class="badge bg-warning">معلق</span>
                                                        break;
                                                    case "مكتمل":
                                                        <span class="badge bg-success">مكتمل</span>
                                                        break;
                                                    case "ملغي":
                                                        <span class="badge bg-danger">ملغي</span>
                                                        break;
                                                    case "قيد التنفيذ":
                                                        <span class="badge bg-info">قيد التنفيذ</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@order.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@order.TotalPoints نقطة</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("Details", "Order", new { id = order.Id })"
                                                       class="btn btn-sm btn-primary" title="عرض التفاصيل">
                                                        <i class="fas fa-eye"></i>
                                                    </a>

                                                    @if (order.Status != "ملغي" && order.Status != "مكتمل")
                                                    {
                                                        <button type="button" class="btn btn-sm btn-danger"
                                                                title="إلغاء الطلب"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#cancelModal"
                                                                data-order-id="@order.Id"
                                                                data-order-points="@order.TotalPoints">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <i class="fas fa-clipboard-list fa-5x text-muted"></i>
                            </div>
                            <h4>لا توجد طلبات سابقة</h4>
                            <p class="text-muted">لم تقم بإنشاء أي طلبات بعد</p>
                            <a href="@Url.Action("Index", "Shop")" class="btn btn-primary mt-2">
                                <i class="fas fa-shopping-bag"></i> تسوق الآن
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Cancel Confirmation -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cancelModalLabel">تأكيد إلغاء الطلب</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    هل أنت متأكد من إلغاء هذا الطلب؟
                </div>
                <p>سيتم إرجاع <strong id="orderPoints"></strong> نقطة لحسابك عند إلغاء الطلب.</p>
                <p class="text-muted">لا يمكن التراجع عن هذا الإجراء.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <form method="post" style="display: inline;">
                    <input type="hidden" id="orderIdToCancel" name="id" />
                    <button type="submit" class="btn btn-danger" id="confirmCancelBtn">
                        <i class="fas fa-times me-1"></i> تأكيد الإلغاء
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Handle cancel modal
    document.addEventListener('DOMContentLoaded', function() {
        const cancelModal = document.getElementById('cancelModal');
        if (cancelModal) {
            cancelModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const orderId = button.getAttribute('data-order-id');
                const orderPoints = button.getAttribute('data-order-points');

                document.getElementById('orderIdToCancel').value = orderId;
                document.getElementById('orderPoints').textContent = orderPoints;

                const form = cancelModal.querySelector('form');
                form.action = '@Url.Action("Cancel", "Order")/' + orderId;
            });
        }
    });
</script>