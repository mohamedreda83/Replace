@model List<SmartRecycle.Models.Invoice>

@{
    ViewData["Title"] = "فواتيري";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">فواتيري</h3>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>رقم الفاتورة</th>
                                        <th>رقم الطلب</th>
                                        <th>تاريخ الإنشاء</th>
                                        <th>إجمالي النقاط</th>
                                        <th>الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var invoice in Model)
                                    {
                                        <tr>
                                            <td>@invoice.InvoiceNumber</td>
                                            <td>@invoice.OrderId</td>
                                            <td>@invoice.CreatedDate.ToString("yyyy/MM/dd HH:mm")</td>
                                            <td>@invoice.TotalPoints</td>
                                            <td>
                                                <a asp-action="ViewInvoice" asp-route-id="@invoice.Id"
                                                   class="btn btn-info btn-sm">
                                                    <i class="fas fa-eye"></i> عرض
                                                </a>
                                                <a asp-action="DownloadInvoice" asp-route-id="@invoice.Id"
                                                   class="btn btn-primary btn-sm">
                                                    <i class="fas fa-download"></i> تحميل
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            لا توجد فواتير متاحة حالياً
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>