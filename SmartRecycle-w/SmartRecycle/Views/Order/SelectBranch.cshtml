@model SmartRecycle.Models.Order
@{
    ViewData["Title"] = "اختيار فرع الاستلام";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-info text-white text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-map-marker-alt"></i>
                        اختيار فرع الاستلام
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="fas fa-clipboard-list fa-3x text-info"></i>
                        </div>
                        <h5>طلب رقم: <span class="badge bg-primary">#@Model.Id</span></h5>
                        <p class="text-muted">يرجى اختيار الفرع المناسب لك لاستلام طلبك</p>
                    </div>

                    <form asp-action="SelectBranch" method="post">
                        <input type="hidden" name="orderId" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold mb-3">
                                <i class="fas fa-store text-success"></i>
                                الفروع المتاحة:
                            </label>

                            <div class="row">
                                @foreach (var branch in ViewBag.AvailableBranches)
                                {
                                    <div class="col-md-6 mb-3">
                                        <div class="branch-option">
                                            <input class="form-check-input" type="radio"
                                                   name="selectedBranch" value="@branch.Value"
                                                   id="branch_@branch.Value.Replace(" ", "_")" required>
                                            <label class="form-check-label w-100 p-3 rounded border text-center"
                                                   for="branch_@branch.Value.Replace(" ", "_")">
                                                <div class="branch-icon mb-2">
                                                    <i class="fas fa-building fa-2x text-primary"></i>
                                                </div>
                                                <div class="branch-name fw-bold">
                                                    @branch.Text
                                                </div>
                                                <small class="text-muted">متاح للاستلام</small>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            <strong>تنبيه:</strong> بعد اختيار الفرع، ستحصل على كود الطلب للتوجه إلى الفرع المحدد
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="fas fa-check"></i> تأكيد الاختيار
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-lg px-4 ms-2">
                                <i class="fas fa-arrow-left"></i> رجوع
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .branch-option {
        position: relative;
    }

        .branch-option input[type="radio"] {
            position: absolute;
            opacity: 0;
        }

        .branch-option label {
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid #e9ecef !important;
        }

            .branch-option label:hover {
                border-color: #007bff !important;
                background-color: #f8f9fa;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,123,255,0.2);
            }

        .branch-option input[type="radio"]:checked + label {
            border-color: #28a745 !important;
            background-color: #d4edda;
            color: #155724;
        }

            .branch-option input[type="radio"]:checked + label .branch-icon i {
                color: #28a745 !important;
            }

    .branch-icon {
        transition: all 0.3s ease;
    }
</style>