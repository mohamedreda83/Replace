@model IEnumerable<SmartRecycle.Models.Product>
@{
    ViewData["Title"] = "إدارة المنتجات";
}

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">إدارة المنتجات</h3>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-lg me-1"></i> إضافة منتج جديد
            </a>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>الصورة</th>
                            <th>اسم المنتج</th>
                            <th>الفئة</th>
                            <th>سعر النقاط</th>
                            <th>المخزون</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" style="height: 50px; width: auto;" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                                    }
                                </td>
                                <td>@item.Name</td>
                                <td>@item.Category?.Name</td>
                                <td>@item.PointsPrice</td>
                                <td>
                                    @if (item.Stock > 10)
                                    {
                                        <span class="badge bg-success">@item.Stock</span>
                                    }
                                    else if (item.Stock > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@item.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.Stock</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success">متاح</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">غير متاح</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                            <i class="bi bi-pencil-square"></i> تعديل
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i> حذف
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>