@model SmartRecycle.Models.Product
@{
    ViewData["Title"] = "حذف منتج";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">حذف منتج</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        هل أنت متأكد من رغبتك في حذف هذا المنتج؟ هذا الإجراء لا يمكن التراجع عنه.
                    </div>

                    <div class="row mt-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="col-md-4 text-center mb-3">
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid img-thumbnail" style="max-height: 150px;" />
                            </div>
                        }
                        <div class="col">
                            <dl class="row">
                                <dt class="col-sm-4">اسم المنتج:</dt>
                                <dd class="col-sm-8">@Model.Name</dd>

                                <dt class="col-sm-4">الفئة:</dt>
                                <dd class="col-sm-8">@Model.Category.Name</dd>

                                <dt class="col-sm-4">سعر النقاط:</dt>
                                <dd class="col-sm-8">@Model.PointsPrice</dd>

                                <dt class="col-sm-4">المخزون:</dt>
                                <dd class="col-sm-8">@Model.Stock</dd>
                            </dl>
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-right me-1"></i> رجوع للقائمة
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i> تأكيد الحذف
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>