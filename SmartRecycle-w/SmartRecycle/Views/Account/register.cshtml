@{
  
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Recycling - Register</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/Login.css">
</head>
<body>
    @{
        bool isRtl = false;
        try
        {
            isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
        }
        catch { }
    }
    <div dir="@(isRtl ? "rtl" : "ltr")" class="Login-container">
        <div class="row g-0 h-100">
            <!-- Registration Form Section -->
            <div class="col-lg-5 d-flex align-items-center justify-content-center">
                <div class="login-form">
                    <div class="form-heading">
                        <img src="~/Images/black-recycle-icon-png-2.png" alt="Logo" class="app-logo">
                        <h3 class="mt-4">Smart Recycling</h3>
                        <p class="text-muted">Create a new account</p>
                    </div>

                    @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()

                        @if (ViewBag.LoginError != null)
                        {
                            <div class="alert alert-danger">
                                @ViewBag.LoginError
                            </div>
                        }

                        <div class="mb-3">
                            <label for="Username" class="input-label">Username</label>
                            <div class="input-group">
                                <i class="fas fa-user"></i>
                                @Html.TextBox("Username", "", new { @class = "form-control", placeholder = "Enter your username", required = "required" })
                                <div class="invalid-feedback">
                                    Please choose a username.
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="Password" class="input-label">Password</label>
                            <div class="input-group">
                                <i class="fas fa-lock"></i>
                                @Html.Password("Password", "", new { @class = "form-control", placeholder = "Create a password", required = "required" })
                                <div class="invalid-feedback">
                                    Please choose a password.
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="Phone" class="input-label">Phone Number</label>
                            <div class="input-group">
                                <i class="fas fa-phone"></i>
                                @Html.TextBox("Phone", "", new { @class = "form-control", placeholder = "Enter your phone number", required = "required" })
                                <div class="invalid-feedback">
                                    Please enter your phone number.
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="Address" class="input-label">Address</label>
                            <div class="input-group">
                                <i class="fas fa-map-marker-alt"></i>
                                @Html.TextArea("Address", "", new { @class = "form-control", placeholder = "Enter your address", rows = "2", required = "required" })
                                <div class="invalid-feedback">
                                    Please enter your address.
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="Branch" class="input-label">Nearest Branch</label>
                            <div class="input-group">
                                <i class="fas fa-building"></i>
                                <select name="Branch" class="form-control" required>
                                    <option value="" selected disabled>Select nearest branch</option>
                                    <option value="Smoha">سموحة</option>
                                    <option value="Glim">جليم</option>
                                    <option value="AlNasr">النصر</option>
                                    <option value="SidiGaber">سيدي جابر</option>
                                </select>
                                <div class="invalid-feedback">
                                    Please select your nearest branch.
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary mb-3">Register</button>

                        <div class="text-center mt-3">
                            <span class="text-muted">Already have an account? </span>
                            <a href="@Url.Action("Login", "Account")" class="register-link">Login</a>
                        </div>
                    }
                </div>
            </div>

            <!-- Background Image/Graphics Section -->
            <div class="col-lg-7 d-none d-lg-block">
                <div class="sidebar">
                    <div class="illustration-container">
                        <img src="~/Images/recycling-illustration.png" alt="Recycling Illustration" class="illustration">
                    </div>
                    <div class="sidebar-text">
                        <h2>Make an Impact</h2>
                        <p>Join our community and track your recycling achievements</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        // Form validation
        (function() {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function(form) {
                form.addEventListener('submit', function(event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
</body>
</html>