@model SmartRecycle.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, var(--dark-green), var(--primary-green));
        color: white;
        padding: 40px 20px;
        border-radius: 15px;
        margin-bottom: 40px;
        text-align: center;
    }

        .dashboard-header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .dashboard-header p {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .quick-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 25px;
        margin-bottom: 40px;
    }

    .stat-box {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-box::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, var(--primary-green), var(--light-green));
        }

        .stat-box:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        }

    .stat-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        opacity: 0.8;
    }

    .stat-number {
        font-size: 3rem;
        font-weight: bold;
        color: var(--dark-green);
        margin: 10px 0;
    }

    .stat-label {
        font-size: 1.1rem;
        color: #666;
        font-weight: 500;
    }

    .stat-box.pending {
        border-right: 5px solid var(--warning-orange);
    }

    .stat-box.success {
        border-right: 5px solid var(--primary-green);
    }

    .stat-box.info {
        border-right: 5px solid var(--accent-blue);
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .action-card {
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .action-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

    .action-card-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
        display: block;
    }

    .action-card h3 {
        color: var(--dark-green);
        margin-bottom: 10px;
        font-size: 1.3rem;
    }

    .action-card p {
        color: #666;
        margin: 0;
    }

    .action-card .badge {
        margin-top: 10px;
        display: inline-block;
    }

    .recent-activity {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

        .recent-activity h2 {
            color: var(--dark-green);
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 3px solid var(--primary-green);
        }

    .activity-item {
        padding: 15px;
        border-right: 4px solid var(--primary-green);
        background: #f9f9f9;
        border-radius: 8px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

        .activity-item:hover {
            transform: translateX(-5px);
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

    .activity-time {
        color: #999;
        font-size: 0.9rem;
        margin-top: 5px;
    }

    .welcome-message {
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
        padding: 30px;
        border-radius: 15px;
        margin-bottom: 30px;
        border-right: 5px solid var(--primary-green);
    }

        .welcome-message h2 {
            color: var(--dark-green);
            margin-bottom: 10px;
        }

        .welcome-message p {
            color: #333;
            font-size: 1.1rem;
        }
</style>

<div class="admin-container">
    <!-- Welcome Message -->
    <div class="welcome-message fade-in">
        <h2>👋 مرحباً، @User.Identity?.Name!</h2>
        <p>مرحباً بك في لوحة تحكم Replace. من هنا يمكنك إدارة جميع جوانب النظام.</p>
    </div>

    <!-- Quick Stats -->
    <div class="quick-stats">
        <div class="stat-box success fade-in" style="animation-delay: 0.1s;">
            <div class="stat-icon">⭐</div>
            <div class="stat-number">@Model.TotalRatings</div>
            <div class="stat-label">إجمالي التقييمات</div>
        </div>

        <div class="stat-box pending fade-in" style="animation-delay: 0.2s;">
            <div class="stat-icon">⏳</div>
            <div class="stat-number">@Model.PendingRatings</div>
            <div class="stat-label">تقييمات قيد المراجعة</div>
        </div>

        <div class="stat-box info fade-in" style="animation-delay: 0.3s;">
            <div class="stat-icon">📧</div>
            <div class="stat-number">@Model.TotalMessages</div>
            <div class="stat-label">إجمالي الرسائل</div>
        </div>

        <div class="stat-box pending fade-in" style="animation-delay: 0.4s;">
            <div class="stat-icon">🔔</div>
            <div class="stat-number">@Model.UnreadMessages</div>
            <div class="stat-label">رسائل غير مقروءة</div>
        </div>

        <div class="stat-box success fade-in" style="animation-delay: 0.5s;">
            <div class="stat-icon">📊</div>
            <div class="stat-number">@Model.AverageRating.ToString("F1")</div>
            <div class="stat-label">متوسط التقييم</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <h2 style="color: var(--dark-green); margin-bottom: 25px; font-size: 2rem;">⚡ إجراءات سريعة</h2>

    <div class="quick-actions">
        <a href="@Url.Action("Rules")" class="action-card fade-in">
            <span class="action-card-icon">📋</span>
            <h3>إدارة القواعد</h3>
            <p>إضافة وتعديل قواعد وشروط استخدام الموقع</p>
        </a>

        <a href="@Url.Action("Ratings")" class="action-card fade-in" style="animation-delay: 0.1s;">
            <span class="action-card-icon">⭐</span>
            <h3>إدارة التقييمات</h3>
            <p>مراجعة والموافقة على تقييمات المستخدمين</p>
            @if (Model.PendingRatings > 0)
            {
                <span class="badge badge-warning">@Model.PendingRatings جديد</span>
            }
        </a>

        <a href="@Url.Action("Messages")" class="action-card fade-in" style="animation-delay: 0.2s;">
            <span class="action-card-icon">💬</span>
            <h3>الرسائل والاستفسارات</h3>
            <p>الرد على رسائل وشكاوى المستخدمين</p>
            @if (Model.UnreadMessages > 0)
            {
                <span class="badge badge-warning">@Model.UnreadMessages غير مقروء</span>
            }
        </a>

        <a href="@Url.Action("Index", "Products")" class="action-card fade-in" style="animation-delay: 0.3s;">
            <span class="action-card-icon">📦</span>
            <h3>إدارة المنتجات</h3>
            <p>إضافة وتعديل المنتجات والفئات</p>
        </a>

        <a href="@Url.Action("Index", "Orders")" class="action-card fade-in" style="animation-delay: 0.4s;">
            <span class="action-card-icon">🛍️</span>
            <h3>إدارة الطلبات</h3>
            <p>متابعة وتسليم طلبات العملاء</p>
        </a>

        <a href="@Url.Action("Index", "Users")" class="action-card fade-in" style="animation-delay: 0.5s;">
            <span class="action-card-icon">👥</span>
            <h3>إدارة المستخدمين</h3>
            <p>عرض ومراقبة حسابات المستخدمين</p>
        </a>
    </div>

    <!-- Recent Activity -->
    <div class="recent-activity fade-in">
        <h2>📊 نشاط حديث</h2>

        <div class="activity-item">
            <strong>تقييم جديد</strong>
            <p>تم إضافة تقييم جديد من مستخدم ويحتاج إلى مراجعة</p>
            <div class="activity-time">منذ 5 دقائق</div>
        </div>

        <div class="activity-item">
            <strong>رسالة جديدة</strong>
            <p>استفسار جديد من عميل بخصوص نظام النقاط</p>
            <div class="activity-time">منذ 15 دقيقة</div>
        </div>

        <div class="activity-item">
            <strong>طلب جديد</strong>
            <p>تم إنشاء طلب جديد رقم #12345</p>
            <div class="activity-time">منذ ساعة</div>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <a href="@Url.Action("Activity")" class="btn-primary">عرض جميع الأنشطة</a>
        </div>
    </div>

    <!-- System Info -->
    <div style="margin-top: 40px; padding: 20px; background: #f9f9f9; border-radius: 10px;">
        <h3 style="color: var(--dark-green); margin-bottom: 15px;">ℹ️ معلومات النظام</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
            <div>
                <strong>التاريخ:</strong> @DateTime.Now.ToString("dd/MM/yyyy")
            </div>
            <div>
                <strong>الوقت:</strong> @DateTime.Now.ToString("hh:mm tt")
            </div>
            <div>
                <strong>الإصدار:</strong> v1.0.0
            </div>
            <div>
                <strong>الحالة:</strong> <span style="color: var(--primary-green);">● نشط</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Refresh stats every 30 seconds
        setInterval(() => {
            location.reload();
        }, 30000);

        // Add fade-in animation to elements
        document.addEventListener('DOMContentLoaded', () => {
            const fadeElements = document.querySelectorAll('.fade-in');
            fadeElements.forEach((el, index) => {
                setTimeout(() => {
                    el.style.opacity = '0';
                    el.style.transform = 'translateY(20px)';
                    el.style.transition = 'all 0.5s ease';

                    setTimeout(() => {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }, 50);
                }, index * 100);
            });
        });
    </script>
}