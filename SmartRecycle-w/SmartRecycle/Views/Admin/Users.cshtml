@model IEnumerable<SmartRecycle.Models.User>
@{
    ViewData["Title"] = "Manage Users";
}
<link rel="stylesheet" href="~/css/admin-styles.css">
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header pb-0 d-flex justify-content-between align-items-center">
                    <h6>Manage Users</h6>
                    <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-primary btn-sm">
                        <i class="fas fa-user-plus me-2"></i> Create New User
                    </a>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mx-4 mt-3">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">ID</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">User</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Contact</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Branch</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Role</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Points</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex px-3 py-1">
                                                <div class="d-flex flex-column justify-content-center">
                                                    <h6 class="mb-0 text-sm">@user.Id</h6>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex px-3 py-1">
                                                <div class="d-flex flex-column justify-content-center">
                                                    <h6 class="mb-0 text-sm">@user.Username</h6>
                                                    <p class="text-xs text-secondary mb-0">@user.Gmail</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <p class="text-xs font-weight-bold mb-0">@user.Phone</p>
                                            <p class="text-xs text-secondary mb-0">@user.Address</p>
                                        </td>
                                        <td>
                                            <p class="text-xs font-weight-bold mb-0">@user.Branch</p>
                                        </td>
                                        <td>
                                            <span class="badge badge-sm bg-@(user.Roles.ToLower() == "admin" ? "danger" : "success")">@user.Roles</span>
                                        </td>
                                        <td>
                                            <p class="text-xs font-weight-bold mb-0">@user.Points</p>
                                        </td>
                                        <td class="align-middle">
                                            <div class="d-flex">
                                                <a href="@Url.Action("EditUser", "Admin", new { id = user.Id })" class="btn btn-link text-secondary mb-0">
                                                    <i class="fas fa-user-edit"></i>
                                                </a>

                                                <form id="changeRoleForm-@user.Id" method="post" action="@Url.Action("ChangeRole", "Admin")">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <input type="hidden" name="role" id="role-@user.Id" value="" />
                                                    <div class="dropdown">
                                                        <button class="btn btn-link text-secondary mb-0" type="button" id="roleDropdown-@user.Id" data-bs-toggle="dropdown" aria-expanded="false">
                                                            <i class="fas fa-user-tag"></i>
                                                        </button>
                                                        <ul class="dropdown-menu" aria-labelledby="roleDropdown-@user.Id">
                                                            <li>
                                                                <a class="dropdown-item" href="#" onclick="changeRole(@user.Id, 'user')">User</a>
                                                            </li>
                                                            <li>
                                                                <a class="dropdown-item" href="#" onclick="changeRole(@user.Id, 'admin')">Admin</a>
                                                            </li>
                                                        </ul>
                                                    </div>
                                                </form>

                                                <form id="deleteUserForm-@user.Id" method="post" action="@Url.Action("DeleteUser", "Admin", new { id = user.Id })" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                    <button type="submit" class="btn btn-link text-danger mb-0">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeRole(userId, roleName) {
            document.getElementById(`role-${userId}`).value = roleName;
            document.getElementById(`changeRoleForm-${userId}`).submit();
        }
    </script>
}