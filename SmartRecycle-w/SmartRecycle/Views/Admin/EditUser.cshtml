@model SmartRecycle.Models.User
@{
    ViewData["Title"] = "Edit User";
}
<link rel="stylesheet" href="~/css/admin-styles.css">
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header pb-0">
                    <h6>Edit User: @Model.Username</h6>
                </div>
                <div class="card-body px-4 pt-0 pb-2">
                    <form asp-action="EditUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" name="Id" value="@Model.Id" />

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Username" class="form-control-label">Username</label>
                                    <input type="text" id="Username" name="Username" class="form-control" value="@Model.Username" required>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="Username" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="PasswordHash" class="form-control-label">Password</label>
                                    <input type="password" id="PasswordHash" name="PasswordHash" class="form-control" value="@Model.PasswordHash" required>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="PasswordHash" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Gmail" class="form-control-label">Email</label>
                                    <input type="email" id="Gmail" name="Gmail" class="form-control" value="@Model.Gmail">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Phone" class="form-control-label">Phone Number</label>
                                    <input type="tel" id="Phone" name="Phone" class="form-control" value="@Model.Phone" required>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Address" class="form-control-label">Address</label>
                                    <textarea id="Address" name="Address" class="form-control" rows="3" required>@Model.Address</textarea>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Branch" class="form-control-label">Branch</label>
                                    <select id="Branch" name="Branch" class="form-control" required>
                                        <option value="">Select nearest branch</option>
                                        @if (Model.Branch == "Smoha")
                                        {
                                            <option value="Smoha" selected>Smoha</option>
                                        }
                                        else
                                        {
                                            <option value="Smoha">Smoha</option>
                                        }

                                        @if (Model.Branch == "Glim")
                                        {
                                            <option value="Glim" selected>Glim</option>
                                        }
                                        else
                                        {
                                            <option value="Glim">Glim</option>
                                        }

                                        @if (Model.Branch == "AlNasr")
                                        {
                                            <option value="AlNasr" selected>AlNasr</option>
                                        }
                                        else
                                        {
                                            <option value="AlNasr">AlNasr</option>
                                        }

                                        @if (Model.Branch == "SidiGaber")
                                        {
                                            <option value="SidiGaber" selected>SidiGaber</option>
                                        }
                                        else
                                        {
                                            <option value="SidiGaber">SidiGaber</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Roles" class="form-control-label">Role</label>
                                    <select id="Roles" name="Roles" class="form-control" required>
                                        @if (Model.Roles?.ToLower() == "admin")
                                        {
                                            <option value="user">User</option>
                                            <option value="admin" selected>Admin</option>
                                        }
                                        else
                                        {
                                            <option value="user" selected>User</option>
                                            <option value="admin">Admin</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Points" class="form-control-label">Points</label>
                                    <input type="number" id="Points" name="Points" class="form-control" value="@Model.Points">
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12 text-end">
                                <a href="@Url.Action("Users", "Admin")" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">Update User</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
}