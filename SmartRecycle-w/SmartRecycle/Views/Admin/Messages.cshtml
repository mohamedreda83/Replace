@model List<SmartRecycle.Models.ContactMessage>
@{
    ViewData["Title"] = "الرسائل والاستفسارات";
}

<style>
    .message-type-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .type-question {
        background: #2196F3;
        color: white;
    }

    .type-complaint {
        background: #f44336;
        color: white;
    }

    .type-suggestion {
        background: #4CAF50;
        color: white;
    }

    .type-other {
        background: #9E9E9E;
        color: white;
    }

    .message-card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 15px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        cursor: pointer;
        border-right: 5px solid transparent;
    }

        .message-card:hover {
            transform: translateX(-5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.15);
        }

        .message-card.unread {
            background: #e8f5e9;
            border-right-color: var(--primary-green);
        }

    .message-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .message-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .message-subject {
        font-size: 1.2rem;
        font-weight: bold;
        color: var(--dark-green);
        margin: 10px 0;
    }

    .message-preview {
        color: #666;
        line-height: 1.5;
        max-height: 60px;
        overflow: hidden;
    }

    .message-meta {
        display: flex;
        gap: 20px;
        margin-top: 15px;
        font-size: 0.9rem;
        color: #999;
    }

    .quick-actions {
        display: flex;
        gap: 10px;
    }
</style>

<div class="admin-container">
    <div class="page-header">
        <h2>📧 الرسائل والاستفسارات</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-label">إجمالي الرسائل</div>
            <div class="stat-value">@Model.Count</div>
        </div>
        <div class="stat-card" style="background: linear-gradient(135deg, #f44336, #ef5350);">
            <div class="stat-label">غير مقروءة</div>
            <div class="stat-value">@Model.Count(m => !m.IsRead)</div>
        </div>
        <div class="stat-card" style="background: linear-gradient(135deg, #2196F3, #64B5F6);">
            <div class="stat-label">أسئلة</div>
            <div class="stat-value">@Model.Count(m => m.Type == "Question")</div>
        </div>
        <div class="stat-card" style="background: linear-gradient(135deg, #FF9800, #FFB74D);">
            <div class="stat-label">شكاوى</div>
            <div class="stat-value">@Model.Count(m => m.Type == "Complaint")</div>
        </div>
    </div>

    <div class="filter-tabs">
        <a href="@Url.Action("Messages", new { filter = "all" })"
           class="filter-tab @(ViewBag.Filter == "all" ? "active" : "")">
            الكل (@Model.Count)
        </a>
        <a href="@Url.Action("Messages", new { filter = "unread" })"
           class="filter-tab @(ViewBag.Filter == "unread" ? "active" : "")">
            غير مقروءة (@Model.Count(m => !m.IsRead))
        </a>
        <a href="@Url.Action("Messages", new { filter = "questions" })"
           class="filter-tab @(ViewBag.Filter == "questions" ? "active" : "")">
            أسئلة (@Model.Count(m => m.Type == "Question"))
        </a>
        <a href="@Url.Action("Messages", new { filter = "complaints" })"
           class="filter-tab @(ViewBag.Filter == "complaints" ? "active" : "")">
            شكاوى (@Model.Count(m => m.Type == "Complaint"))
        </a>
        <a href="@Url.Action("Messages", new { filter = "suggestions" })"
           class="filter-tab @(ViewBag.Filter == "suggestions" ? "active" : "")">
            اقتراحات (@Model.Count(m => m.Type == "Suggestion"))
        </a>
    </div>

    @if (Model.Any())
    {
        <div>
            @foreach (var message in Model)
            {
                <div class="message-card @(message.IsRead ? "" : "unread")"
                     onclick="window.location.href='@Url.Action("ViewMessage", new { id = message.Id })'">
                    <div class="message-header">
                        <div class="message-info">
                            <div class="message-type-icon type-@message.Type.ToLower()">
                                @switch (message.Type)
                                {
                                    case "Question":
                                        <span>❓</span>
                                        break;
                                    case "Complaint":
                                        <span>⚠️</span>
                                        break;
                                    case "Suggestion":
                                        <span>💡</span>
                                        break;
                                    default:
                                        <span>📧</span>
                                        break;
                                }
                            </div>
                            <div>
                                <div style="font-weight: bold; color: var(--dark-green);">@message.Email</div>
                                <div style="font-size: 0.9rem; color: #999;">@message.Type</div>
                            </div>
                        </div>
                        <div>
                            @if (!message.IsRead)
                            {
                                <span class="badge" style="background: #f44336; color: white;">جديد</span>
                            }
                            @if (message.IsReplied)
                            {
                                <span class="badge badge-active">✓ تم الرد</span>
                            }
                        </div>
                    </div>

                    <div class="message-subject">@message.Subject</div>
                    <div class="message-preview">@message.Message</div>

                    <div class="message-meta">
                        <span>📅 @message.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")</span>
                        @if (message.IsReplied)
                        {
                            <span>✉️ رد بواسطة @message.RepliedBy في @message.RepliedAt?.ToString("dd/MM/yyyy")</span>
                        }
                    </div>

                    <div class="quick-actions" onclick="event.stopPropagation();">
                        <a href="@Url.Action("ViewMessage", new { id = message.Id })" class="btn-sm" style="background: #2196F3; color: white;">
                            👁️ عرض
                        </a>
                        @if (!message.IsReplied)
                        {
                            <a href="@Url.Action("ReplyMessage", new { id = message.Id })" class="btn-sm" style="background: #4CAF50; color: white;">
                                ↩️ رد
                            </a>
                        }
                        @if (!message.IsRead)
                        {
                            <form asp-action="MarkAsRead" asp-route-id="@message.Id" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm" style="background: #FF9800; color: white;">
                                    ✓ تم القراءة
                                </button>
                            </form>
                        }
                        <form asp-action="DeleteMessage" asp-route-id="@message.Id" method="post" style="display: inline;"
                              onsubmit="return confirm('هل أنت متأكد من حذف هذه الرسالة؟')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-sm btn-delete">🗑️</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i>📧</i>
            <h3>لا توجد رسائل</h3>
            <p>ستظهر الرسائل والاستفسارات هنا</p>
        </div>
    }
</div>