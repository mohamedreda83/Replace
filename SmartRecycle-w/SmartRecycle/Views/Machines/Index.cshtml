@model IEnumerable<SmartRecycle.Models.Machines>

@{
    ViewData["Title"] = "إدارة الماكينات";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>
                <i class="fas fa-cog"></i> إدارة الماكينات
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> إضافة ماكينة جديدة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>رقم الماكينة</th>
                                <th>الموقع</th>
                                <th>الحالة</th>
                                <th>آخر صيانة</th>
                                <th>URL GUID</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var machine in Model)
                            {
                                <tr>
                                    <td><strong>#@machine.Id</strong></td>
                                    <td>
                                        <i class="fas fa-map-marker-alt text-primary"></i> @machine.Location
                                    </td>
                                    <td>
                                        @if (machine.Status == "Active")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> نشطة
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times"></i> غير نشطة
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (machine.LastMaintenanceDate.HasValue)
                                        {
                                            <small>@machine.LastMaintenanceDate.Value.ToString("yyyy-MM-dd")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">لا يوجد</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted font-monospace">
                                            @machine.URL_GUID.ToString().Substring(0, 8)...
                                        </small>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@machine.Id"
                                               class="btn btn-sm btn-info" title="التفاصيل">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@machine.Id"
                                               class="btn btn-sm btn-warning" title="تعديل">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal@(machine.Id)"
                                                    title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Delete Confirmation Modal -->
                                <div class="modal fade" id="deleteModal@(machine.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header bg-danger text-white">
                                                <h5 class="modal-title">تأكيد الحذف</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>هل أنت متأكد من حذف الماكينة <strong>#@machine.Id</strong> الموجودة في <strong>@machine.Location</strong>؟</p>
                                                <p class="text-danger"><i class="fas fa-exclamation-triangle"></i> هذا الإجراء لا يمكن التراجع عنه!</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                                                <form asp-action="Delete" asp-route-id="@machine.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger">
                                                        <i class="fas fa-trash"></i> حذف نهائي
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                    <h4>لا توجد ماكينات</h4>
                    <p class="text-muted">ابدأ بإضافة ماكينة جديدة</p>
                    <a asp-action="Create" class="btn btn-success mt-3">
                        <i class="fas fa-plus"></i> إضافة أول ماكينة
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}