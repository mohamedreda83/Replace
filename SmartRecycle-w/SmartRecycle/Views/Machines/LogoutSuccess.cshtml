<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout Success</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- ملف CSS الموحد -->
    <link href="~/css/machine-pages-unified-style.css" rel="stylesheet">
</head>
<body>
    <div class="scan-line"></div>
    <div class="particles-bg"></div>
    <div id="canvas-container"></div>

    <div class="content-overlay">
        <div class="success-card glass-panel">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>

            <h2 class="glow-text">تم تسجيل الخروج بنجاح</h2>

            <p class="message">@ViewBag.Message</p>

            <div class="info-box">
                <i class="fas fa-info-circle"></i>
                <p class="mb-0">تم تغيير رمز الجلسة. يجب مسح QR Code جديد للدخول مرة أخرى</p>
            </div>

            <div style="margin-top: 30px;">
                <i class="fas fa-shield-alt" style="font-size: 40px; color: #2ecc71;"></i>
                <p class="glow-text" style="font-weight: bold; margin-top: 15px;">
                    تم تأمين الماكينة
                </p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="~/js/webgl-background-script.js"></script>
</body>
</html>