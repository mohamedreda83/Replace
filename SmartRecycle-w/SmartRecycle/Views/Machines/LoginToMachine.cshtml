<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Machine Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- ملف CSS الموحد -->
    <link href="~/css/machine-pages-unified-style.css" rel="stylesheet">
</head>
<body>
    <div class="scan-line"></div>
    <div class="particles-bg"></div>
    <div id="canvas-container"></div>

    <div class="content-overlay">
        <div class="machine-login-card">
            <div class="machine-icon">
                <i class="fas fa-recycle"></i>
            </div>

            <h2 class="text-center mb-3">تسجيل دخول الماكينة</h2>

            <div class="machine-info">
                <i class="fas fa-map-marker-alt"></i>
                <strong>الموقع:</strong> @ViewBag.MachineLocation
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="LoginToMachine">
                <input type="hidden" name="machineId" value="@ViewBag.MachineId" />
                <input type="hidden" name="urlGuid" value="@ViewBag.UrlGuid" />

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-user"></i> اسم المستخدم
                    </label>
                    <input type="text" class="form-control" name="username" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-lock"></i> كلمة المرور
                    </label>
                    <input type="password" class="form-control" name="password" required>
                </div>

                <button type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
                </button>
            </form>

            <div class="session-timer">
                <i class="fas fa-clock"></i> مدة الجلسة: 5 دقائق
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="~/js/webgl-background-script.js"></script>
</body>
</html>